# Image and container names
IMAGE_NAME=iroffer-dinoex
IMAGE_TAG=local
CONTAINER_NAME=iroffer

# Build arguments (mapped to Dockerfile ARG values)
CONT_IMG_VER=v1.0
IROFFER_USER_ID=999
IROFFER_GROUP_ID=999
IROFFER_VER=snap
IROFFER_SHA256=FFCEDD67B124C2B2BB9B9FD1883D38112076E1412BC1625590C58B95B396E0A9

# Runtime environment (mapped to Dockerfile ENV defaults)
IROFFER_USER=iroffer
IROFFER_CONFIG_DIR=/config
IROFFER_DATA_DIR=/files
IROFFER_LOG_DIR=/logs
IROFFER_CONFIG_FILE_NAME=mybot.config

# Host directories
HOST_CONFIG_DIR=./config
HOST_DATA_DIR=./files
HOST_LOG_DIR=./logs

# Container port range
PORT_RANGE=30000-31000

